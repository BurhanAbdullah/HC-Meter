live)
while true
do
clear
bash "$BASE_DIR/modules/dashboard.sh"
bash "$BASE_DIR/modules/processes.sh"
bash "$BASE_DIR/modules/network.sh"
bash "$BASE_DIR/modules/risk_score.sh"
sleep 5
done
;;

malware)
bash "$BASE_DIR/modules/malware_scan.sh"
;;

network)
bash "$BASE_DIR/modules/network.sh"
;;

processes)
bash "$BASE_DIR/modules/processes.sh"
;;

filesystem)
bash "$BASE_DIR/modules/filesystem.sh"
;;
