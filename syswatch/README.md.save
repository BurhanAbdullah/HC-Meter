# Project Architecture
syswatch/
│
├── syswatch # Main CLI
│
├── core/
│ ├── engine.sh # Module execution engine
│ ├── alerts.sh # Alert system
│ ├── logger.sh # Logging system
│ └── threat_score.sh # Threat scoring engine
│
├── modules/
│ ├── environment.sh
│ ├── system_health.sh
│ ├── integrity_baseline.sh
│ ├── integrity_check.sh
│ ├── network_monitor.sh
│ ├── malware_scan.sh
│ └── security_scan.sh
│
├── database/
│ └── integrity.db
│
└── logs/
├── system.log
└── intrusions.log


